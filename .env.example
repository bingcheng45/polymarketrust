# ============================================================
# Polymarket Arbitrage Bot - Environment Configuration
# ============================================================
# Copy this file to .env and fill in your values.
# Run `cargo run --bin biogen` to generate API keys.

# --- Wallet / Authentication ---
# Your Ethereum private key (without 0x prefix)
PRIVATE_KEY=your_private_key_here

# Polymarket CLOB API credentials (generate with `cargo run --bin biogen`)
POLY_API_KEY=
POLY_API_SECRET=
POLY_API_PASSPHRASE=

# Proxy wallet address (required if SIGNATURE_TYPE >= 1)
POLY_PROXY_ADDRESS=

# Signature type: 0=EOA, 1=Poly Proxy Magic Link, 2=Gnosis Safe
SIGNATURE_TYPE=1

# --- Market Selection ---
# Market slug prefix (e.g., btc-updown-15m, btc-updown-5m)
# Comma-separated for multiple markets: btc-updown-15m,btc-updown-5m
MARKET_SLUG=btc-updown-15m

# --- Trading Parameters ---
# Maximum shares per arbitrage execution (stability-first default)
MAX_TRADE_SIZE=12

# Legacy liquidity sizing knob (still used by trigger heuristics)
MIN_LIQUIDITY_SIZE=10

# Minimum paired shares to attempt (after fees). Polymarket orderMinSize is typically 5.
MIN_PAIRED_SHARES=5

# Child order sizing for adaptive taker batching (must stay >= exchange min order size)
# Stability-first profile prefers fewer, larger child submits.
MIN_CHILD_ORDER_SIZE=5
TARGET_CHILD_ORDER_SIZE=12
MAX_TAKER_BATCHES=1

# Hedge sizing floors:
# - sell paths generally require >=5 shares
# - buy hedge paths can be smaller (to neutralize dust faster when venue permits)
MIN_RESCUE_BUY_SHARES=1
MIN_IMBALANCE_BUY_SHARES=1
MIN_IMBALANCE_SELL_SHARES=5

# Minimum net profit threshold in USD to execute an arb
MIN_NET_PROFIT_USD=0.08

# Resting (maker/post-only) minimum structural edge per share.
# Prevents posting quotes on razor-thin edges that cannot absorb one-sided fill risk.
RESTING_MIN_EDGE_PER_SHARE=0.01

# Skip arb if either leg is priced below this (filters near-resolved markets)
MIN_LEG_PRICE=0.12

# --- Risk Management ---
# Paper trading mode (uses virtual $1000 balance, no real orders)
MOCK_CURRENCY=false

# Daily loss circuit breaker (USD)
MAX_DAILY_LOSS_USD=10.0

# Consecutive failure circuit breaker
MAX_CONSECUTIVE_FAILURES=5

# Circuit breaker cooldown in milliseconds (5 minutes)
CIRCUIT_BREAKER_COOLDOWN_MS=300000

# --- Execution Mode ---
# Enable WebSocket feed (real-time orderbook)
WS_ENABLED=true

# Pre-sign orders speculatively while evaluating profitability
PRE_SIGN_ENABLED=true

# Strategy mode: taker | maker | post-only
# - taker: immediate FAK/FOK execution path
# - maker: resting GTC quotes (can still take if mispriced)
# - post-only: resting GTC quotes with postOnly=true (never crosses as taker)
#   In post-only mode, quote size is auto-inflated when needed so net shares
#   can still satisfy MIN_PAIRED_SHARES after fees.
STRATEGY_MODE=taker

# Legacy compatibility toggle (used only when STRATEGY_MODE is unset)
# If true, defaults to maker mode.
MAKER_MODE_ENABLED=false

# Ticks below best ask for maker bids
MAKER_SPREAD_TICKS=2

# Max wait time for GTC order fills (milliseconds)
GTC_TAKER_TIMEOUT_MS=5000

# Taker order type: FAK (default) or FOK
TAKER_ORDER_TYPE=FAK

# Hedge/sell-back order type: stability-first uses FAK to reduce hard FOK misses
HEDGE_ORDER_TYPE=FAK

# Strict neutrality gate: blocks new entries while imbalance/recovery ambiguity is unresolved
STRICT_NEUTRAL_MODE=true

# Resume entries only when net YES-NO imbalance is within this share threshold
NEUTRALITY_RESUME_NET_SHARES=0.25

# Lock new entries for deterministic recovery after ambiguous submit timeout
TIMEOUT_RECOVERY_LOCK_SECS=10
TIMEOUT_RECOVERY_POLL_MS=200

# Drop stale signals before submit if too old (milliseconds)
PRE_SUBMIT_SIGNAL_MAX_AGE_MS=350

# Drop if current pair cost drift exceeds this since detection
PRE_SUBMIT_PAIR_DRIFT_MAX=0.006

# Require this fraction of target size still available at cap prices
PRE_SUBMIT_MIN_LIQ_FACTOR=0.95

# Use User WS fill stream as primary fill source (with polling fallback)
WS_FILL_PRIMARY=true

# Poll fallback interval when WS fill stream is stale/missing (milliseconds)
WS_FILL_FALLBACK_POLL_MS=300

# Adaptive trigger minimum interval for actionable deltas (milliseconds)
ADAPTIVE_THROTTLE_MIN_MS=0

# Adaptive trigger debounce during bursty/non-actionable deltas (milliseconds)
ADAPTIVE_THROTTLE_BURST_DEBOUNCE_MS=8

# Minimum tick move considered actionable
ACTIONABLE_DELTA_MIN_TICKS=1

# Retry policy for transient transport/API failures
SDK_POST_TIMEOUT_MS=3000
SDK_CANCEL_TIMEOUT_MS=1200
SDK_ORDER_LOOKUP_TIMEOUT_MS=1200
POST_BATCH_MAX_RETRIES=1
CANCEL_ORDER_MAX_RETRIES=1
ORDER_LOOKUP_MAX_RETRIES=1
SDK_RETRY_BASE_DELAY_MS=60
SDK_RETRY_MAX_DELAY_MS=600
SDK_RETRY_JITTER_MS=35

# Gamma discovery retries (helps recover from transient API/network outages)
GAMMA_REQUEST_RETRIES=2
GAMMA_RETRY_BASE_MS=300

# Emit degraded-mode warning once per minute after this many seconds of continuous discovery failures
DISCOVERY_DEGRADED_SECS=60

# Network path: bypass HTTP(S)_PROXY/ALL_PROXY by default for lower latency
DISABLE_SYSTEM_PROXY=true

# Run new execution engine in shadow mode
SHADOW_ENGINE_ENABLED=true

# Allow shadow engine to actually submit orders
SHADOW_ENGINE_SEND_ORDERS=false

# Interval for merge reconciliation cycle (seconds)
MERGE_RECONCILE_INTERVAL_SECS=5

# --- Fee Parameters ---
# Polymarket CLOB dynamic fee: fee = RATE * (price * (1 - price))^EXPONENT
CLOB_FEE_RATE=0.25
CLOB_FEE_EXPONENT=2
